# Database — single Neon PostgreSQL (sellers, products, embeddings, scrape logs). Required for production.
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Optional: if DATABASE_URL is not set, SQLite is used for sellers/products (local dev only).
# SQLITE_DB_PATH=/path/to/profitstory.db

# Auth (multi-tenant)
JWT_SECRET=profitstory-super-secret-key-2026
JWT_EXPIRY_DAYS=7
# Test account (create via Sign up or run: PYTHONPATH=. python -c "from db.database import *; from api.auth import *; ...")
# email: demo@profitstory.ai  password: Demo@1234  business_name: PS Demo Store

# --- LLM: use Gemini (e.g. for detective_node and other agents) ---
# Set both to use Google Gemini instead of OpenAI:
LLM_PROVIDER=gemini
EMBEDDING_PROVIDER=gemini
GOOGLE_API_KEY=your-google-api-key

# Gemini model: default is Gemini 3.1 Flash Lite (faster, cost-effective for Detective node)
# GEMINI_MODEL=gemini-3.1-flash-lite-preview
# Or use: gemini-2.0-flash, gemini-2.5-flash, etc.

# --- Or keep OpenAI (default) ---
# OPENAI_API_KEY=sk-...

# --- Optional: Flipkart fallback when Amazon blocks ---
# FLIPKART_FALLBACK_URL=https://www.flipkart.com/product-name/p/itmXXXX

# --- Optional: Snapdeal fallback (BeautifulSoup); use full product URL or PID ---
# SNAPDEAL_FALLBACK_URL=https://www.snapdeal.com/product/product-slug/626304069296
# SNAPDEAL_FALLBACK_PID=626304069296

# --- Amazon scraping: RapidAPI (preferred) or ScraperAPI ---
# If set, Amazon product + reviews are fetched via RapidAPI "Real-Time Amazon Data".
# RAPIDAPI_KEY=your-rapidapi-key
# RAPIDAPI_AMAZON_HOST=real-time-amazon-data.p.rapidapi.com
# Many RapidAPI Amazon APIs only support US. Use US for reliable RapidAPI; IN for amazon.in (may 403).
# AMAZON_COUNTRY=US
# AMAZON_COUNTRY=IN

# ScraperAPI fallback when RapidAPI is not set or fails.
# SCRAPERAPI_KEY=your-scraperapi-key
