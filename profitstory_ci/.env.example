# Database (required)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# --- LLM: use Gemini when OpenAI quota exceeded ---
# Set both to use Google Gemini instead of OpenAI:
LLM_PROVIDER=gemini
EMBEDDING_PROVIDER=gemini
GOOGLE_API_KEY=your-google-api-key

# Optional: Gemini model (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# --- Or keep OpenAI (default) ---
# OPENAI_API_KEY=sk-...

# --- Optional: Flipkart fallback when Amazon blocks ---
# FLIPKART_FALLBACK_URL=https://www.flipkart.com/product-name/p/itmXXXX

# --- Optional: Snapdeal fallback (BeautifulSoup); use full product URL or PID ---
# SNAPDEAL_FALLBACK_URL=https://www.snapdeal.com/product/product-slug/626304069296
# SNAPDEAL_FALLBACK_PID=626304069296

# --- Amazon scraping: RapidAPI (preferred) or ScraperAPI ---
# If set, Amazon product + reviews are fetched via RapidAPI "Real-Time Amazon Data".
# RAPIDAPI_KEY=your-rapidapi-key
# RAPIDAPI_AMAZON_HOST=real-time-amazon-data.p.rapidapi.com
# Many RapidAPI Amazon APIs only support US. Use US for reliable RapidAPI; IN for amazon.in (may 403).
# AMAZON_COUNTRY=US
# AMAZON_COUNTRY=IN

# ScraperAPI fallback when RapidAPI is not set or fails.
# SCRAPERAPI_KEY=your-scraperapi-key
